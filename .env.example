# Database connection (PostgreSQL with TimescaleDB)
DATABASE_URL=postgresql://user:password@host:5432/tanker_tracker

# AISStream.io WebSocket API key
AISSTREAM_API_KEY=your_aisstream_api_key

# JWT secret for session tokens (minimum 32 characters)
JWT_SECRET=your_jwt_secret_min_32_chars

# Bcrypt hash of shared password for authentication
PASSWORD_HASH=bcrypt_hash_of_shared_password

# Mapbox access token for map rendering
MAPBOX_ACCESS_TOKEN=your_mapbox_token
